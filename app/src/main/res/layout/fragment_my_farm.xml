<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_xl">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/my_farm_title"
            android:textAppearance="@style/TextAppearance.AgriSense.Headline" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:text="@string/farm_overview_subtitle"
            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />







        <!-- RecyclerView for Dynamic Farms -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/farmsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="@dimen/spacing_md" />



        <!-- Add Farm -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/addFarmCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashed_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="@dimen/icon_container"
                    android:layout_height="@dimen/icon_container"
                    android:layout_marginEnd="@dimen/spacing_md"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/icon_bg_green"
                    android:padding="11dp"
                    android:src="@drawable/ic_add"
                    android:tint="@color/primary_green" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_farm_title"
                        android:textColor="@color/primary_green"
                        android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/add_farm_subtitle"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
