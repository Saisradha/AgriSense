<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_xl">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/my_farm_title"
            android:textAppearance="@style/TextAppearance.AgriSense.Headline" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:text="@string/farm_overview_subtitle"
            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />


        <!-- Farm Overview Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_card_lg"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="@color/secondary_green"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="@dimen/spacing_md"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_green"
                        android:padding="14dp"
                        android:src="@drawable/ic_leaf"
                        android:tint="@color/primary_green" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/farm_name_label"
                            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                        <TextView
                            android:id="@+id/fieldNameText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/field_name_placeholder"
                            android:textAppearance="@style/TextAppearance.AgriSense.Title" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/fieldStatusBadge"
                        style="@style/Widget.AgriSense.StatusChip"
                        android:backgroundTint="@color/icon_bg_green"
                        android:text="@string/field_status_healthy"
                        android:textColor="@color/status_healthy" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:background="@color/divider" />

                <!-- Info grid: Crop, Area, Location -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/farm_crop_label"
                            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/farm_crop_value"
                            android:textAppearance="@style/TextAppearance.AgriSense.Body"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/farm_area_label"
                            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/farm_area_value"
                            android:textAppearance="@style/TextAppearance.AgriSense.Body"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="6dp"
                        android:src="@drawable/ic_location"
                        android:tint="@color/primary_green" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/farm_location_label"
                            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/field_alpha_location"
                            android:textAppearance="@style/TextAppearance.AgriSense.Body"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/fieldMoistureText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/field_moisture_label"
                    android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                <TextView
                    android:id="@+id/fieldWateringText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/field_watering_label"
                    android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Widget.AgriSense.SectionHeader"
            android:layout_marginTop="0dp"
            android:text="@string/other_fields_title" />

        <!-- Field Beta -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sm"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_card_sm"
            app:cardElevation="@dimen/card_elevation_sm">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_status_strip"
                    android:backgroundTint="@color/status_medium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginEnd="@dimen/spacing_md"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_orange"
                        android:padding="11dp"
                        android:src="@drawable/ic_leaf"
                        android:tint="@color/accent_orange" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/field_beta_name"
                            android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/field_beta_subtitle"
                            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                    </LinearLayout>

                    <TextView
                        style="@style/Widget.AgriSense.StatusChip"
                        android:backgroundTint="@color/icon_bg_orange"
                        android:text="@string/field_beta_status"
                        android:textColor="@color/status_medium" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Field Gamma -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_card_sm"
            app:cardElevation="@dimen/card_elevation_sm">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_status_strip"
                    android:backgroundTint="@color/status_critical" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginEnd="@dimen/spacing_md"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_red"
                        android:padding="11dp"
                        android:src="@drawable/ic_water_drop"
                        android:tint="@color/status_critical" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/field_gamma_name"
                            android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/field_gamma_subtitle"
                            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                    </LinearLayout>

                    <TextView
                        style="@style/Widget.AgriSense.StatusChip"
                        android:backgroundTint="@color/icon_bg_red"
                        android:text="@string/field_gamma_status"
                        android:textColor="@color/status_critical" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- RecyclerView for Dynamic Farms -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/farmsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="@dimen/spacing_md" />



        <!-- Add Farm -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/addFarmCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashed_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="@dimen/icon_container"
                    android:layout_height="@dimen/icon_container"
                    android:layout_marginEnd="@dimen/spacing_md"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/icon_bg_green"
                    android:padding="11dp"
                    android:src="@drawable/ic_add"
                    android:tint="@color/primary_green" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_farm_title"
                        android:textColor="@color/primary_green"
                        android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/add_farm_subtitle"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
