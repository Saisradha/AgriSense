<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_futuristic_gradient"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_xl">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/primary_green"
                android:textSize="@dimen/text_card_title"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/notifBellContainer"
                android:layout_width="@dimen/icon_container"
                android:layout_height="@dimen/icon_container">

                <ImageView
                    android:layout_width="@dimen/icon_container"
                    android:layout_height="@dimen/icon_container"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/icon_bg_green"
                    android:contentDescription="@string/notif_center_title"
                    android:padding="11dp"
                    android:src="@drawable/ic_notifications"
                    android:tint="@color/primary_green" />

                <View
                    android:id="@+id/notifUnreadDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/status_critical"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

        <!-- Welcome & Farm Selector Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWelcomeGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_greeting"
                    android:textAppearance="@style/TextAppearance.AgriSense.Headline" />

                <TextView
                    android:id="@+id/tvFarmerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Farmer Name"
                    android:textColor="@color/primary_green"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Farm Dropdown Spinner / Selector -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFarmSelector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="12dp"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_liquid_glass_card">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_place"
                        app:tint="@color/primary_green" />

                    <TextView
                        android:id="@+id/tvSelectedFarm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Main Farm"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_green" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_logout"
                        android:rotation="90"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Crop Health Hero Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:cardBackgroundColor="@color/primary_green"
            app:cardCornerRadius="@dimen/radius_card_lg"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="@string/insight_crop_health_title"
                        android:textColor="@color/primary_green_light"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_leaf"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/farmHealthStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/farm_health_status"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_card_title"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/updated_recently"
                        android:textColor="@color/primary_green_light"
                        android:textSize="@dimen/text_caption" />

                </LinearLayout>

                <FrameLayout
                    android:layout_width="@dimen/progress_size_lg"
                    android:layout_height="@dimen/progress_size_lg">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/farmHealthProgress"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="92"
                        app:indicatorColor="@color/white"
                        app:indicatorSize="@dimen/progress_size_lg"
                        app:trackColor="#33FFFFFF"
                        app:trackThickness="@dimen/progress_thickness" />

                    <TextView
                        android:id="@+id/farmHealthValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/farm_health_value"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </FrameLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Farm Status Summary -->
        <TextView
            style="@style/Widget.AgriSense.SectionHeader"
            android:layout_marginTop="0dp"
            android:text="@string/section_farm_status" />

        <!-- Row 1: Moisture + Temperature -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:layout_weight="1"
                app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/radius_card_sm"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/sensor_card_min_height"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md"
                    android:background="@drawable/bg_liquid_glass_card">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_green"
                        android:contentDescription="@string/sensor_soil_moisture"
                        android:padding="8dp"
                        android:src="@drawable/ic_moisture"
                        android:tint="@color/primary_green" />

                    <TextView
                        android:id="@+id/soilMoistureValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="—%"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_card_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/sensor_soil_moisture"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xs"
                android:layout_weight="1"
                app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/radius_card_sm"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/sensor_card_min_height"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md"
                    android:background="@drawable/bg_liquid_glass_card">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_orange"
                        android:contentDescription="@string/sensor_temperature"
                        android:padding="8dp"
                        android:src="@drawable/ic_temperature"
                        android:tint="@color/accent_orange" />

                    <TextView
                        android:id="@+id/temperatureValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="—°C"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_card_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/sensor_temperature"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Row 2: Humidity + Water Level -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:layout_weight="1"
                app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/radius_card_sm"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/sensor_card_min_height"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md"
                    android:background="@drawable/bg_liquid_glass_card">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_blue"
                        android:contentDescription="@string/sensor_humidity"
                        android:padding="8dp"
                        android:src="@drawable/ic_humidity"
                        android:tint="@color/accent_blue" />

                    <TextView
                        android:id="@+id/humidityValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="—%"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_card_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/sensor_humidity"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xs"
                android:layout_weight="1"
                app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/radius_card_sm"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/sensor_card_min_height"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md"
                    android:background="@drawable/bg_liquid_glass_card">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_teal"
                        android:contentDescription="@string/sensor_water_level"
                        android:padding="8dp"
                        android:src="@drawable/ic_water_drop"
                        android:tint="@color/status_info" />

                    <TextView
                        android:id="@+id/waterLevelValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="—%"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_card_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/sensor_water_level"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Smart Insights -->
        <TextView
            style="@style/Widget.AgriSense.SectionHeader"
            android:text="@string/section_smart_insights" />

        <!-- Smart Irrigation Recommendation -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                    android:background="@drawable/bg_liquid_glass_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginEnd="@dimen/spacing_md"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_green"
                        android:padding="11dp"
                        android:src="@drawable/ic_robot"
                        android:tint="@color/primary_green" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/insight_irrigation_title"
                        android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge"
                        android:backgroundTint="@color/icon_bg_green"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="@string/risk_low"
                        android:textColor="@color/status_healthy"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:id="@+id/aiRecommendationText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:lineSpacingMultiplier="1.3"
                    android:text="@string/ai_recommendation_text"
                    android:textAppearance="@style/TextAppearance.AgriSense.Body"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Pump Status -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                    android:background="@drawable/bg_liquid_glass_card">

                <!-- Header row: icon + title + status badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginEnd="@dimen/spacing_md"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_blue"
                        android:padding="11dp"
                        android:src="@drawable/ic_pump"
                        android:tint="@color/accent_blue" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pump_title"
                            android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                        <TextView
                            android:id="@+id/pumpSubtitleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/pump_subtitle"
                            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/pumpStatusBadge"
                        style="@style/Widget.AgriSense.StatusChip"
                        android:backgroundTint="@color/icon_bg_red"
                        android:text="@string/pump_off"
                        android:textColor="@color/status_critical" />

                </LinearLayout>

                <!-- Extended info: Current Mode / Last Activated / Reason -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/pump_mode_current"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                    <TextView
                        android:id="@+id/tvPumpModeInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Automatic"
                        android:textAppearance="@style/TextAppearance.AgriSense.Body"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/pump_last_activated"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                    <TextView
                        android:id="@+id/tvLastActivated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textAppearance="@style/TextAppearance.AgriSense.Body"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/pump_reason_label"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                    <TextView
                        android:id="@+id/tvPumpReason"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pump_reason_ai"
                        android:textAppearance="@style/TextAppearance.AgriSense.Body"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Risk Level row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:src="@drawable/ic_check_circle"
                        android:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/risk_level_title"
                        android:textAppearance="@style/TextAppearance.AgriSense.Body" />

                    <TextView
                        android:id="@+id/riskLevelBadge"
                        style="@style/Widget.AgriSense.StatusChip"
                        android:backgroundTint="@color/icon_bg_green"
                        android:text="@string/risk_low"
                        android:textColor="@color/status_healthy" />

                </LinearLayout>

                <!-- ── Pump Mode selector ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/pump_mode_label"
                    android:textAppearance="@style/TextAppearance.AgriSense.Body"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnModeAuto"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/primary_green"
                        android:text="@string/pump_mode_auto"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:cornerRadius="@dimen/radius_card_sm"
                        app:strokeColor="@color/primary_green"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnModeManual"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:backgroundTint="@android:color/transparent"
                        android:text="@string/pump_mode_manual"
                        android:textColor="@color/primary_green"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:cornerRadius="@dimen/radius_card_sm"
                        app:strokeColor="@color/primary_green"
                        app:strokeWidth="1dp" />

                </LinearLayout>

                <!-- Caption: shown in AUTO mode -->
                <TextView
                    android:id="@+id/tvPumpModeCaption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/pump_caption_auto"
                    android:textAppearance="@style/TextAppearance.AgriSense.Caption"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:visibility="visible" />

                <!-- Water Now button (disabled in AUTO, enabled in MANUAL) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWaterNow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/primary_green"
                    android:text="@string/pump_controlled_auto"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:enabled="false"
                    app:cornerRadius="@dimen/radius_card_sm" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- Water Loss Localization -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                    android:background="@drawable/bg_liquid_glass_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_blue"
                        android:padding="11dp"
                        android:src="@drawable/ic_water_drop"
                        android:tint="@color/accent_blue" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/wl_card_title"
                        android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                    <TextView
                        android:id="@+id/wlStatusBadge"
                        style="@style/Widget.AgriSense.StatusChip"
                        android:backgroundTint="@color/icon_bg_green"
                        android:text="@string/wl_status"
                        android:textColor="@color/status_healthy" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/wl_suspected_boundary"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                    <TextView
                        android:id="@+id/wlBoundaryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textAppearance="@style/TextAppearance.AgriSense.Body"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/wl_estimated_loss"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                    <TextView
                        android:id="@+id/wlEstimatedLossText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— L"
                        android:textAppearance="@style/TextAppearance.AgriSense.Body"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Weather Insights -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_md"
                    android:background="@drawable/bg_liquid_glass_card">

                <ImageView
                    android:layout_width="@dimen/icon_container"
                    android:layout_height="@dimen/icon_container"
                    android:layout_marginEnd="@dimen/spacing_md"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/icon_bg_orange"
                    android:padding="11dp"
                    android:src="@drawable/ic_weather"
                    android:tint="@color/accent_orange" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/insight_weather_title"
                        android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/insight_weather_text"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge"
                    android:backgroundTint="@color/icon_bg_blue"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="@string/insight_weather_status"
                    android:textColor="@color/status_info"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Monthly Savings -->
        <TextView
            style="@style/Widget.AgriSense.SectionHeader"
            android:text="@string/section_savings" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_md"
                    android:background="@drawable/bg_liquid_glass_card">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_blue"
                        android:padding="11dp"
                        android:src="@drawable/ic_water_drop"
                        android:tint="@color/accent_blue" />

                    <TextView
                        android:id="@+id/waterSavedValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="320 L"
                        android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/stat_water_saved"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_orange"
                        android:padding="11dp"
                        android:src="@drawable/ic_bolt"
                        android:tint="@color/accent_orange" />

                    <TextView
                        android:id="@+id/energySavedValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.8 kWh"
                        android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/stat_energy_saved"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_green"
                        android:padding="11dp"
                        android:src="@drawable/ic_savings"
                        android:tint="@color/status_healthy" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹145"
                        android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/stat_money_saved"
                        android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
