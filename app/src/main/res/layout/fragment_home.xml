<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/primary_green"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Bell with unread badge -->
            <FrameLayout
                android:id="@+id/notifBellContainer"
                android:layout_width="@dimen/icon_container"
                android:layout_height="@dimen/icon_container">

                <ImageView
                    android:layout_width="@dimen/icon_container"
                    android:layout_height="@dimen/icon_container"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/icon_bg_green"
                    android:padding="11dp"
                    android:src="@drawable/ic_notifications"
                    android:tint="@color/primary_green"
                    android:contentDescription="@string/notif_center_title" />

                <!-- Red dot badge for unread count -->
                <View
                    android:id="@+id/notifUnreadDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/status_critical"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

        <!-- Greeting -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_greeting"
            android:textColor="?attr/colorOnSurface"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:text="@string/home_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- FARM HEALTH CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@color/primary_green"
            app:cardCornerRadius="@dimen/radius_card_lg"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.1"
                        android:text="@string/farm_health_label"
                        android:textColor="@color/primary_green_light"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_leaf"
                            android:tint="@color/white" />

                        <TextView
                            android:id="@+id/farmHealthStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/farm_health_status"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/updated_recently"
                        android:textColor="@color/primary_green_light"
                        android:textSize="12sp" />

                </LinearLayout>

                <FrameLayout
                    android:layout_width="@dimen/progress_size_lg"
                    android:layout_height="@dimen/progress_size_lg">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/farmHealthProgress"
                        android:layout_width="136dp"
                        android:layout_height="119dp"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="92"
                        app:indicatorColor="@color/white"
                        app:indicatorSize="@dimen/progress_size_lg"
                        app:trackColor="#33FFFFFF"
                        app:trackThickness="@dimen/progress_thickness" />

                    <TextView
                        android:id="@+id/farmHealthValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/farm_health_value"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </FrameLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- AI RECOMMENDATION CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="@dimen/icon_container"
                    android:layout_height="@dimen/icon_container"
                    android:layout_marginEnd="@dimen/spacing_md"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/icon_bg_green"
                    android:padding="11dp"
                    android:src="@drawable/ic_robot"
                    android:tint="@color/primary_green" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_recommendation_label"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/aiRecommendationText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/ai_recommendation_text"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_size"
                    android:layout_height="@dimen/icon_size"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_secondary" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- PUMP STATUS CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginEnd="@dimen/spacing_md"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_blue"
                        android:padding="11dp"
                        android:src="@drawable/ic_pump"
                        android:tint="@color/accent_blue" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pump_title"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/pumpSubtitleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/pump_subtitle"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/pumpStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge"
                        android:backgroundTint="@color/icon_bg_red"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="@string/pump_off"
                        android:textColor="@color/status_critical"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:src="@drawable/ic_check_circle"
                        android:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/risk_level_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/riskLevelBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge"
                        android:backgroundTint="@color/icon_bg_green"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="@string/risk_low"
                        android:textColor="@color/status_healthy"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/primary_green"
                    android:text="@string/water_now"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/radius_card" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- WATER / ENERGY / MONEY SAVED CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_md">

                <!-- Water -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_blue"
                        android:padding="11dp"
                        android:src="@drawable/ic_water_drop"
                        android:tint="@color/accent_blue" />

                    <TextView
                        android:id="@+id/waterSavedValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="320 L"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/stat_water_saved"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Energy -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_orange"
                        android:padding="11dp"
                        android:src="@drawable/ic_bolt"
                        android:tint="@color/accent_orange" />

                    <TextView
                        android:id="@+id/energySavedValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.8 kWh"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/stat_energy_saved"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Money -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_green"
                        android:padding="11dp"
                        android:src="@drawable/ic_savings"
                        android:tint="@color/status_healthy" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹145"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/stat_money_saved"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- SMART WATER LOSS LOCALIZATION CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/icon_container"
                        android:layout_height="@dimen/icon_container"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/icon_bg_blue"
                        android:padding="11dp"
                        android:src="@drawable/ic_water_drop"
                        android:tint="@color/accent_blue" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/wl_card_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/wlStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge"
                        android:backgroundTint="@color/icon_bg_green"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="@string/wl_status"
                        android:textColor="@color/status_healthy"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Leakage status row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/wl_suspected_boundary"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/wlBoundaryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Estimated loss row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/wl_estimated_loss"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/wlEstimatedLossText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— L"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- WATER LOSS SIMULATOR CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:text="@string/wl_simulator_title"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSimNormal"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:backgroundTint="@color/status_healthy"
                    android:text="@string/wl_sim_normal"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:cornerRadius="@dimen/radius_card" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSimEast"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:backgroundTint="@color/status_medium"
                    android:text="@string/wl_sim_east"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:cornerRadius="@dimen/radius_card" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSimWest"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="@color/status_critical"
                    android:text="@string/wl_sim_west"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:cornerRadius="@dimen/radius_card" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>