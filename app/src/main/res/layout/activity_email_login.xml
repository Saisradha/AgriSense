<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_futuristic_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <!-- Futuristic Header Logo & Title -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="56dp"
            android:layout_marginBottom="40dp">

            <View
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_icon_circle"
                android:backgroundTint="#2010B981" />

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="-50dp"
                android:src="@drawable/ic_leaf"
                app:tint="@color/primary_green"
                android:contentDescription="AgriSense Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="AgriSense AI"
                android:textAppearance="@style/TextAppearance.AgriSense.Headline"
                android:textColor="?attr/colorOnSurface"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Future of Automated Smart Farming"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.02" />

        </LinearLayout>

        <!-- Glassmorphic Login Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_liquid_glass_card"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvLoginTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back"
                android:textColor="?attr/colorOnSurface"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLoginSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Enter your email to verify and sign in"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="24dp" />

            <!-- Email Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email_label"
                android:textColor="@color/primary_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/selector_glass_input"
                android:hint="@string/email_hint"
                android:inputType="textEmailAddress"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="@color/text_secondary"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:maxLines="1"
                android:drawableStart="@drawable/ic_place"
                android:drawablePadding="10dp"
                android:drawableTint="@color/text_secondary" />

            <!-- OTP Input Section (Initially Hidden) -->
            <LinearLayout
                android:id="@+id/layoutOtp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvOtpLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Verification Code"
                    android:textColor="@color/primary_green"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etOtp"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/selector_glass_input"
                    android:hint="6-Digit OTP"
                    android:inputType="number"
                    android:maxLength="6"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:maxLines="1"
                    android:letterSpacing="0.1"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_tune"
                    android:drawablePadding="10dp"
                    android:drawableTint="@color/text_secondary" />

            </LinearLayout>

            <!-- Error message view -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/accent_red"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone" />

            <!-- Login Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="Send OTP"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primary_green"
                app:cornerRadius="14dp"
                app:elevation="0dp" />

            <!-- Progress Loader -->
            <ProgressBar
                android:id="@+id/progressLogin"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:indeterminateTint="@color/primary_green"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="@string/phone_terms"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
