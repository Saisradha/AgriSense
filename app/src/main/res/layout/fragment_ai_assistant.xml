<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/chatHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_circle"
            android:backgroundTint="@color/icon_bg_green"
            android:padding="10dp"
            android:src="@drawable/ic_robot"
            android:tint="@color/primary_green" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/assistant_title"
                android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/assistant_status_subtext"
                android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

        </LinearLayout>

        <!-- Folder / Conversations button -->
        <ImageView
            android:id="@+id/btnFolders"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_icon_circle"
            android:backgroundTint="@color/icon_bg_green"
            android:contentDescription="Conversations"
            android:padding="8dp"
            android:src="@drawable/ic_folder"
            android:tint="@color/primary_green" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge"
            android:backgroundTint="@color/icon_bg_green"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="@string/assistant_online"
            android:textColor="@color/status_healthy"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Selection action bar (hidden; appears when multi-select mode is active) -->
    <LinearLayout
        android:id="@+id/selectionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@color/surface"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chatHeader">

        <TextView
            android:id="@+id/selectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 selected"
            android:textAppearance="@style/TextAppearance.AgriSense.CardTitle"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnSelectAll"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select All"
            android:textColor="@color/primary_green"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnDeleteSelected"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete"
            android:textColor="@color/status_critical"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnCancelSelection"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Chat messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="@dimen/spacing_md"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toTopOf="@id/inputBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/selectionBar" />


    <!-- Fixed input bar -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="4dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/chatInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginEnd="92dp"
                android:background="@android:color/transparent"
                android:hint="@string/assistant_chat_hint"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3"
                android:textAppearance="@style/TextAppearance.AgriSense.Body"
                android:textColorHint="@color/text_secondary" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabMicLaunch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/primary_green"
                    android:contentDescription="@string/assistant_tap_to_speak"
                    android:src="@drawable/ic_mic"
                    app:fabCustomSize="40dp"
                    app:maxImageSize="20dp"
                    android:tint="@color/white" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnSend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/primary_green"
                    android:contentDescription="@string/action_ask"
                    android:src="@drawable/ic_send"
                    app:fabCustomSize="40dp"
                    app:maxImageSize="20dp"
                    android:tint="@color/white" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Sidebar Drawer (ChatGPT style) -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AgriSense AI"
            android:textAppearance="@style/TextAppearance.AgriSense.CardTitle"
            android:textSize="20sp"
            android:textColor="@color/primary_green"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnNewChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ New Chat"
            android:backgroundTint="@color/primary_green"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/searchChatsInput"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="Search Chats..."
            android:background="@drawable/bg_chat_input"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:inputType="text"
            android:maxLines="1"
            android:layout_marginBottom="12dp" />

        <ExpandableListView
            android:id="@+id/sidebarExpandableList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:groupIndicator="@null"
            android:divider="@null"
            android:childDivider="@null"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Settings"
                android:textAppearance="@style/TextAppearance.AgriSense.Body"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
