<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/chatHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_circle"
            android:backgroundTint="@color/icon_bg_green"
            android:padding="10dp"
            android:src="@drawable/ic_robot"
            android:tint="@color/primary_green" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/assistant_title"
                android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/assistant_status_subtext"
                android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge"
            android:backgroundTint="@color/icon_bg_green"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="@string/assistant_online"
            android:textColor="@color/status_healthy"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Chat messages -->
    <ScrollView
        android:id="@+id/chatScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:padding="@dimen/spacing_md"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/inputBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chatHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AI greeting bubble (left) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/icon_bg_green"
                    android:padding="7dp"
                    android:src="@drawable/ic_robot"
                    android:tint="@color/primary_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="48dp"
                    android:background="@drawable/bg_chat_bubble_ai"
                    android:lineSpacingMultiplier="1.35"
                    android:padding="@dimen/spacing_md"
                    android:text="@string/voice_greeting"
                    android:textAppearance="@style/TextAppearance.AgriSense.Body" />

            </LinearLayout>

            <!-- User sample bubble (right) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:gravity="end"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="48dp"
                    android:background="@drawable/bg_chat_bubble_user"
                    android:lineSpacingMultiplier="1.35"
                    android:padding="@dimen/spacing_md"
                    android:text="@string/assistant_chat_sample_user"
                    android:textAppearance="@style/TextAppearance.AgriSense.Body"
                    android:textColor="@color/white" />

            </LinearLayout>

            <!-- AI response bubble (left) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/icon_bg_green"
                    android:padding="7dp"
                    android:src="@drawable/ic_robot"
                    android:tint="@color/primary_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="48dp"
                    android:background="@drawable/bg_chat_bubble_ai"
                    android:lineSpacingMultiplier="1.35"
                    android:padding="@dimen/spacing_md"
                    android:text="@string/ai_recommendation_text"
                    android:textAppearance="@style/TextAppearance.AgriSense.Body" />

            </LinearLayout>

            <!-- AI status checklist card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_card_sm"
                app:cardElevation="@dimen/card_elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:text="@string/ai_status_title"
                        android:textAppearance="@style/TextAppearance.AgriSense.CardTitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@drawable/ic_check_circle"
                            android:tint="@color/status_healthy" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ai_status_item_1"
                            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@drawable/ic_check_circle"
                            android:tint="@color/status_healthy" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ai_status_item_2"
                            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@drawable/ic_check_circle"
                            android:tint="@color/status_healthy" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ai_status_item_3"
                            android:textAppearance="@style/TextAppearance.AgriSense.Caption" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- Fixed input bar -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="4dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/chatInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginEnd="48dp"
                android:background="@android:color/transparent"
                android:hint="@string/assistant_chat_hint"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3"
                android:textAppearance="@style/TextAppearance.AgriSense.Body"
                android:textColorHint="@color/text_secondary" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabMicLaunch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/primary_green"
                android:contentDescription="@string/assistant_tap_to_speak"
                android:src="@drawable/ic_mic"
                app:fabCustomSize="40dp"
                app:maxImageSize="20dp"
                android:tint="@color/white" />

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
