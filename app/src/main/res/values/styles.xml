<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Typography -->
    <style name="TextAppearance.AgriSense.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.AgriSense.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.AgriSense.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_section</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.AgriSense.CardTitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">@dimen/text_card_title</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.AgriSense.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.AgriSense.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Cards -->
    <style name="Widget.AgriSense.Card" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@android:color/transparent</item>
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="strokeColor">@android:color/transparent</item>
    </style>

    <style name="Widget.AgriSense.Card.Hero" parent="Widget.AgriSense.Card">
        <item name="cardCornerRadius">@dimen/radius_card_lg</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- Section label above card groups -->
    <style name="Widget.AgriSense.SectionHeader" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">@style/TextAppearance.AgriSense.SectionTitle</item>
        <item name="android:layout_marginBottom">@dimen/spacing_sm</item>
        <item name="android:layout_marginTop">@dimen/spacing_lg</item>
    </style>

    <!-- Status chips -->
    <style name="Widget.AgriSense.StatusChip" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/bg_badge</item>
    </style>

</resources>
